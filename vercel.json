{
  "version": 2,
  "rewrites": [
    { "source": "/api/analyze", "destination": "/api/analyze.py" },
    { "source": "/api/send", "destination": "/api/send.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Powered-By", "value": "Ndiaye-Techn-Pro-Engine" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
